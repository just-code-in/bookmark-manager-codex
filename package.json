{
  "name": "bookmark-manager-codex",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev -w @bookmark-manager/api",
    "dev:web": "npm run dev -w @bookmark-manager/web -- --host 127.0.0.1 --port 4173",
    "build": "npm run build -ws --if-present",
    "check": "npm run check -ws --if-present"
  }
}
