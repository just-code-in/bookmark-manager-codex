# Runtime config
NODE_ENV=development
PORT=4040

# Secrets
OPENAI_API_KEY=your_openai_api_key_here

# Optional model overrides
TRIAGE_CATEGORY_MODEL=gpt-4.1-mini
TRIAGE_SUMMARY_MODEL=gpt-4.1-mini
TRIAGE_CATEGORY_BATCH_SIZE=12
TRIAGE_SUMMARY_BATCH_SIZE=12
TRIAGE_MISSING_OUTPUT_RETRY_ATTEMPTS=2
TRIAGE_MISSING_OUTPUT_RETRY_BATCH_SIZE=4
